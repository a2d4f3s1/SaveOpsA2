# Allowlist-style .gitignore:
# ignore everything by default, then explicitly re-include what is tracked.
# Anything not listed below (e.g. .claude/, dist/, local notes) never enters git.
/*

# --- tracked content ---
!/.gitignore
!/README.md
!/CHANGELOG.md
!/docs/
!/saveopsa2/

# --- generated files inside tracked dirs ---
__pycache__/
*.pyc
